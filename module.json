{
  "id": "actor-jb2a-animations",
  "title": "JB2A Actor Set Animations",
  "description": "Adds a dedicated tab to Actor sheets to configure JB2A/Sequencer animations and provides a macro API to play them.",
  "version": "0.0.1",
  "authors": [
    {
      "name": "manoloel"
    }
  ],
  "compatibility": {
    "minimum": "12",
    "verified": "13"
  },
  "relationships": {
    "requires": [
      {
        "id": "sequencer",
        "type": "module",
        "manifest": "https://foundryvtt.com/packages/sequencer"
      }
    ],
    "recommends": [
      {
        "id": "JB2A_DnD5e",
        "type": "module",
        "manifest": "https://foundryvtt.com/packages/JB2A_DnD5e"
      }
    ]
  },
  "esmodules": [
    "scripts/module.js"
  ],
  "styles": [
    "styles/module.css"
  ],
  "languages": [
    {
      "lang": "en",
      "name": "English",
      "path": "lang/en.json"
    },
    {
      "lang": "ru",
